{
  "name": "bobospay/bobospay-php",
  "description": "Php sdk of Bobospay - Online payment solution by credit card and mobile money",
  "keywords": [
    "bobospay",
    "api",
    "payment processing"
  ],
  "homepage": "https://bobospay.com/",
  "type": "library",
  "require": {
    "php": "^8.1",
    "guzzlehttp/guzzle": "^7.10",
    "guzzlehttp/psr7": "^2.8"
  },
  "require-dev": {
"phpunit/phpunit": "^11.0 || ^12.0",
    "phpstan/phpstan": "^2.1",
    "mockery/mockery": "^1.6",
    "friendsofphp/php-cs-fixer": "^3.94"
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "analyse": "vendor/bin/phpstan analyse --no-progress",
    "style": "vendor/bin/php-cs-fixer --standard=PSR2 -n src tests *.php"
  },
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Bobospay\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Bobospay\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Bobospay"
    }
  ],
  "extra": {
    "laravel": {
      "providers": [
        "Bobospay\\Integrations\\Laravel\\BobospayServiceProvider"
      ],
      "aliases": {
        "Bobospay": "Bobospay\\Integrations\\Laravel\\BobospayFacade"
      }
    }
  },
  "minimum-stability": "stable"
}
